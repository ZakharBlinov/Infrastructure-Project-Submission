[web_servers]
web1 ansible_host=${web1_ip} ansible_user=vagrant ansible_ssh_private_key_file=.vagrant/machines/web-server-1/virtualbox/private_key
web2 ansible_host=${web2_ip} ansible_user=vagrant ansible_ssh_private_key_file=.vagrant/machines/web-server-2/virtualbox/private_key

[all:vars]
ansible_python_interpreter=/usr/bin/python3